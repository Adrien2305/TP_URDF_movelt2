<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot_arm">

  <xacro:property name="PI" value="3.14159265358979323846"/>

  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>

  <!-- WORLD -->
  <link name="world"/>

  <joint name="world_fixed" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>

  <!-- BASE_LINK -->
  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="-0.5 -0.5 0"/>
      <geometry>
        <mesh filename="package://robot_arm_description/meshes/basement.stl"
              scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.015"/>
      <geometry>
        <cylinder radius="0.07" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- BASE_PLATE -->
  <link name="base_plate">
    <visual>
      <origin rpy="0 0 0" xyz="-0.39 -0.39 -0.56"/>
      <geometry>
        <mesh filename="package://robot_arm_description/meshes/base_plate.stl"
              scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- joint1 : base_link -> base_plate, hauteur 3.07cm -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child  link="base_plate"/>
    <origin rpy="0 0 0" xyz="0 0 0.0307"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-PI}" upper="${PI}" effort="50" velocity="1.0"/>
  </joint>

  <!-- FORWARD_DRIVE_ARM -->
  <link name="forward_drive_arm">
    <visual>
      <origin rpy="0 -${PI/2} ${PI/2}" xyz="0.19 0.06 -0.08"/>
      <geometry>
        <mesh filename="package://robot_arm_description/meshes/forward_drive_arm.stl"
              scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.04"/>
      <geometry>
        <box size="0.03 0.03 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0003" ixy="0" ixz="0"
               iyy="0.0003" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- joint2 : base_plate -> forward_drive_arm, hauteur 3.5cm -->
  <joint name="joint2" type="revolute">
    <parent link="base_plate"/>
    <child  link="forward_drive_arm"/>
    <origin rpy="0 0 0" xyz="0 0 0.035"/>
    <axis xyz="1 0 0"/>
    <limit lower="${-PI/2}" upper="${PI/2}" effort="30" velocity="1.0"/>
  </joint>

  <!-- HORIZONTAL_ARM -->
  <link name="horizontal_arm">
    <visual>
      <origin rpy="${PI/2} 0 ${PI/2}" xyz="-0.03 -0.4 -0.06"/>
      <geometry>
        <mesh filename="package://robot_arm_description/meshes/horizontal_arm.stl"
              scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin rpy="0 ${PI/2} 0" xyz="0.04 0 0"/>
      <geometry>
        <box size="0.08 0.03 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0003" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <!-- joint3 : forward_drive_arm -> horizontal_arm, hauteur 8cm -->
  <joint name="joint3" type="revolute">
    <parent link="forward_drive_arm"/>
    <child  link="horizontal_arm"/>
    <origin rpy="0 0 0" xyz="0 0 0.08"/>
    <axis xyz="1 0 0"/>
    <limit lower="${-PI/2}" upper="${PI/2}" effort="30" velocity="1.0"/>
  </joint>

  <!-- CLAW_SUPPORT -->
  <link name="claw_support">
    <visual>
      <origin rpy="0 0 ${PI/2}" xyz="0 -0.05 -0.15"/>
      <geometry>
        <mesh filename="package://robot_arm_description/meshes/claw_support.stl"
              scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- joint_claw : horizontal_arm -> claw_support, distance 8.2cm -->
  <joint name="joint_claw" type="revolute">
    <parent link="horizontal_arm"/>
    <child  link="claw_support"/>
    <origin rpy="0 0 0" xyz="0.082 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-PI/2}" upper="${PI/2}" effort="20" velocity="1.0"/>
  </joint>

  <!-- GRIPPER_RIGHT -->
  <link name="gripper_right">
    <visual>
      <origin rpy="0 0 -${PI/2}" xyz="-0.1 0.5 -0.1"/>
      <geometry>
        <mesh filename="package://robot_arm_description/meshes/right_finger.stl"
              scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0.02 0"/>
      <geometry>
        <box size="0.01 0.04 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- joint4 : prismatique gripper droit -->
  <joint name="joint4" type="prismatic">
    <parent link="claw_support"/>
    <child  link="gripper_right"/>
    <origin rpy="0 0 0" xyz="0.022 0 0.01"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.022" effort="10" velocity="0.2"/>
  </joint>

  <!-- GRIPPER_LEFT -->
  <link name="gripper_left">
    <visual>
      <origin rpy="0 0 -${PI/2}" xyz="-0.04 0.5 -0.1"/>
      <geometry>
        <mesh filename="package://robot_arm_description/meshes/left_finger.stl"
              scale="0.01 0.01 0.01"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0.02 0"/>
      <geometry>
        <box size="0.01 0.04 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- joint5 : prismatique gripper gauche (mimic) -->
  <joint name="joint5" type="prismatic">
    <parent link="claw_support"/>
    <child  link="gripper_left"/>
    <origin rpy="0 0 0" xyz="-0.022 0 0.01"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.022" upper="0.0" effort="10" velocity="0.2"/>
    <mimic joint="joint4" multiplier="-1"/>
  </joint>

</robot>
